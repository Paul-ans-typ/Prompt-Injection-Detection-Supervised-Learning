\newlabel{fig:roc_enhanced}{{7}{32}{ROC curves for the Enhanced baseline across all evaluation splits}{figure.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Precision--Recall curves for the Enhanced baseline. The improved AP on deepset (0.713 vs. 0.677) confirms the value of character n-grams and handcrafted features for generalization.}}{32}{figure.8}\protected@file@percent }
\newlabel{fig:pr_enhanced}{{8}{32}{Precision--Recall curves for the Enhanced baseline. The improved AP on deepset (0.713 vs. 0.677) confirms the value of character n-grams and handcrafted features for generalization}{figure.8}{}}
