\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Confusion matrices for the Simple baseline on the validation (left) and test (right) splits. The model achieves balanced performance across both classes within the training distribution.}}{28}{figure.1}\protected@file@percent }
