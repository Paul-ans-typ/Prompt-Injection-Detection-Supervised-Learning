\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Confusion matrix for the Simple baseline on the held-out deepset benchmark. The high number of false negatives (malicious prompts classified as benign) reveals poor generalization to unseen injection styles.}}{29}{figure.2}\protected@file@percent }
\newlabel{fig:cm_simple_deepset}{{2}{29}{Confusion matrix for the Simple baseline on the held-out deepset benchmark. The high number of false negatives (malicious prompts classified as benign) reveals poor generalization to unseen injection styles}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces ROC curves for the Simple baseline across all evaluation splits. The near-perfect AUC on val/test contrasts sharply with the degraded AUC on deepset.}}{29}{figure.3}\protected@file@percent }
\newlabel{fig:roc_simple}{{3}{29}{ROC curves for the Simple baseline across all evaluation splits. The near-perfect AUC on val/test contrasts sharply with the degraded AUC on deepset}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Precision--Recall curves for the Simple baseline. The high average precision on val/test confirms strong in-distribution performance, while the deepset curve reveals the model's inability to maintain precision at reasonable recall levels for unseen attacks.}}{30}{figure.4}\protected@file@percent }
\newlabel{fig:pr_simple}{{4}{30}{Precision--Recall curves for the Simple baseline. The high average precision on val/test confirms strong in-distribution performance, while the deepset curve reveals the model's inability to maintain precision at reasonable recall levels for unseen attacks}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Confusion matrices for the Enhanced baseline on the validation (left) and test (right) splits. Compared to the Simple baseline, both false positives and false negatives are reduced.}}{31}{figure.5}\protected@file@percent }
\newlabel{fig:cm_enhanced_val_test}{{5}{31}{Confusion matrices for the Enhanced baseline on the validation (left) and test (right) splits. Compared to the Simple baseline, both false positives and false negatives are reduced}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Confusion matrix for the Enhanced baseline on the held-out deepset benchmark. While generalization improves over the Simple baseline, recall on malicious prompts remains low (47.9\%), indicating that traditional ML features alone are insufficient for robust out-of-distribution detection.}}{31}{figure.6}\protected@file@percent }
\newlabel{fig:cm_enhanced_deepset}{{6}{31}{Confusion matrix for the Enhanced baseline on the held-out deepset benchmark. While generalization improves over the Simple baseline, recall on malicious prompts remains low (47.9\%), indicating that traditional ML features alone are insufficient for robust out-of-distribution detection}{figure.6}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.6}Baseline Limitations and Motivation for Deep Learning}{31}{subsubsection.4.3.6}\protected@file@percent }
